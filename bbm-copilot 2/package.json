    "dev": "esbuild src/index.jsx --bundle --outfile=public/app.js --loader:.jsx=jsx --define:process.env.NODE_ENV='\"development\"' --sourcemap"
  },
  "dependencies": {
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  }
}
